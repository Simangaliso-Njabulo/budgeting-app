# Application
APP_NAME=MyBudgeting API
APP_VERSION=1.0.0
DEBUG=true

# Database
# SQLite (default - for local development, no setup required):
DATABASE_URL=sqlite+aiosqlite:///./budgeting_app.db

# PostgreSQL (for production or when you have PostgreSQL installed):
# DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/budgeting_app

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - Allowed origins (comma-separated for multiple)
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Email (for password reset - optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
